{
  "name": "pizi-platform",
  "version": "1.0.0",
  "private": true,
  "description": "PIZI - PG Aggregator Platform (Node + Next.js)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "db:migrate": "cd apps/api && pnpm prisma migrate dev",
    "db:push": "cd apps/api && pnpm prisma db push",
    "db:studio": "cd apps/api && pnpm prisma studio",
    "db:seed": "cd apps/api && pnpm prisma db seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "postinstall": "pnpm --filter @pizi/api exec prisma generate"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^5.0.0"
  }
}
