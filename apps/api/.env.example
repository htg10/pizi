# ============================================
# PIZI API — Environment Variables
# Copy this to .env and fill in values
# ============================================

# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://pizi_user:pizi_pass_2026@localhost:3306/pizi_db"

# For Hostinger production:
# DATABASE_URL="mysql://u112235086_findpizi:YOUR_PASS@srv-db.hstgr.io:3306/u112235086_findpizi"

# JWT Auth
JWT_SECRET=your_super_secret_min_32_chars_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# Redis (for queues, cache, sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# SMS (MSG91 or TextGuru)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_key
MSG91_SENDER_ID=PIZI
MSG91_TEMPLATE_OTP=your_template_id

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_app_password
MAIL_FROM="Pizi <noreply@pizi.in>"

# File Storage (Cloudflare R2 / S3 compatible)
STORAGE_DRIVER=local
# For production use R2:
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=xxx
# R2_ACCESS_KEY=xxx
# R2_SECRET_KEY=xxx
# R2_BUCKET=pizi-uploads
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Google Maps
GOOGLE_MAPS_API_KEY=your_key

# Sentry (optional)
SENTRY_DSN=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://pizi.in
